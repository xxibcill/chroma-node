{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "dist/main",
    "rootDir": "src",
    "types": ["node", "electron"],
    "declaration": true,
    "sourceMap": true
  },
  "include": ["src/main", "src/preload", "src/shared"],
  "exclude": ["**/*.test.ts", "**/*.test.tsx"]
}
